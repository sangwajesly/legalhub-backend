  <diagram id="diagram_rag" name="RAG Pipeline">
    <mxGraphModel dx="1200" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- User Query Start -->
        <mxCell id="rag_start" value="Citizen Types Legal Query" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#FDFCF9;strokeColor=#121315;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="40" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Greeting Decider -->
        <mxCell id="dec_greet" value="Is Greeting /&#xa;Short Query?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#B89868;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="130" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Build Chat Context Prompt -->
        <mxCell id="proc_context" value="Build Chat Context&#xa;Prompt&#xa;(No RAG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#121315;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="140" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Query Expansion -->
        <mxCell id="proc_expand" value="Query Expansion&#xa;(Translate to Cameroonian&#xa;Legal Terms)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#121315;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="250" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Off-Topic Decider -->
        <mxCell id="dec_offtopic" value="Is Off-Topic?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#B89868;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="350" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Build No-Docs Prompt -->
        <mxCell id="proc_nodocs" value="Build No-Docs Prompt&#xa;(LEGALHUB_NO_DOCS&#xa;System Prompt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#121315;align=center;" vertex="1" parent="1">
          <mxGeometry x="580" y="360" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- FAISS Retrieval -->
        <mxCell id="proc_retrieve" value="FAISS Retrieval&#xa;(Semantic Search)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#121315;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="470" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- FAISS Vector DB -->
        <mxCell id="db_faiss" value="FAISS Vector Store&#xa;(Cameroon Legal Docs)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#1C1B19;textColor=#FAF9F5;strokeColor=#121315;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="450" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Threshold Decider -->
        <mxCell id="dec_threshold" value="Docs Match&#xa;Score &gt;= 0.3?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#B89868;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="570" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- Prompt Augmentation -->
        <mxCell id="proc_augment" value="Prompt Augmentation&#xa;(Embed content with&#xa;Source &amp; Page citation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#121315;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="690" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- LLM Generation -->
        <mxCell id="proc_llm" value="Gemini 2.5 Flash&#xa;LLM Generation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B89868;textColor=#FAF9F5;strokeColor=#B89868;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="790" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Firestore Persist -->
        <mxCell id="proc_persist" value="Persist Message &amp;&#xa;Response in DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF9F5;strokeColor=#121315;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="890" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Firestore DB -->
        <mxCell id="db_firestore" value="Firestore Database&#xa;(Chat Sessions)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#1C1B19;textColor=#FAF9F5;strokeColor=#121315;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="870" width="140" height="100" as="geometry" />
        </mxCell>

        <!-- Yield Stream End -->
        <mxCell id="rag_end" value="Stream Response to Web UI" style="rounded=1;whiteSpace=wrap;html=1;arcSize=50;fillColor=#FDFCF9;strokeColor=#121315;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="340" y="990" width="160" height="50" as="geometry" />
