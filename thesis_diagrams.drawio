        <mxCell id="msg_confirm_render" value="29. Display confirmed dashboard status" style="html=1;verticalAlign=bottom;endArrow=dash;endFill=0;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="line_front" target="line_lawyer">
