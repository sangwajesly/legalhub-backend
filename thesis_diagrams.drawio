        <!-- User Entity -->
        <mxCell id="ent_user" value="USER&#xa;-----------------------------&#xa;+ uid (PK)&#xa;email&#xa;displayName&#xa;role&#xa;phoneNumber&#xa;createdAt" style="shape=swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;" vertex="1" parent="1">
