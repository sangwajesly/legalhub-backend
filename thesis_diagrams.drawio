        <mxCell id="flow_10" value="NO" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;html=1;labelBackgroundColor=#FFFFFF;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="dec_threshold" target="proc_nodocs">
          <mxGeometry relative="1" as="geometry">
