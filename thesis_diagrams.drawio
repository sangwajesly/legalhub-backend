        <mxCell id="msg_confirm_ret" value="28. Return confirmed booking details" style="html=1;verticalAlign=bottom;endArrow=dash;endFill=0;labelBackgroundColor=#FFFFFF;" edge="1" parent="1" source="line_back" target="line_front">
