# Local FAISS settings (default)
USE_REMOTE_VECTOR_STORE=False
VECTOR_STORE_TYPE=local

# Pinecone (optional - enable only in production)
# Do NOT commit your real API key. Use secrets in your deployment platform.
USE_REMOTE_VECTOR_STORE=True
VECTOR_STORE_TYPE=pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=legalhub_documents

# Google Gemini key (for embeddings)
GOOGLE_API_KEY=
